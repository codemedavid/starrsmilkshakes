# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=sb_publishable_xxx
SUPABASE_SERVICE_ROLE_KEY=eyJ...your-service-role-key
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...your-anon-key

# Lalamove
NEXT_PUBLIC_LALAMOVE_FUNCTION_URL=/api/lalamove
LALAMOVE_API_KEY=pk_test_xxx
LALAMOVE_API_SECRET=sk_test_xxx

# ImageKit
NEXT_PUBLIC_IMAGEKIT_PUBLIC_KEY=public_xxxxxxxxxxxx
IMAGEKIT_PRIVATE_KEY=private_xxxxxxxxxxxx

# Admin Auth
ADMIN_PASSWORD=<strong-random-password>
ADMIN_SESSION_SECRET=<generate-with: openssl rand -hex 32>
SUPER_ADMIN_PASSWORD=<strong-random-password>

# PostHog Analytics
POSTHOG_API_KEY=phc_xxx
POSTHOG_HOST=https://us.i.posthog.com

# Facebook Messenger
FACEBOOK_APP_ID=your-facebook-app-id
NEXT_PUBLIC_FACEBOOK_APP_ID=your-facebook-app-id
FACEBOOK_APP_SECRET=<from-meta-developer-console>
FACEBOOK_VERIFY_TOKEN=<generate-with: openssl rand -hex 16>
MESSENGER_SESSION_SECRET=<generate-with: openssl rand -hex 32>

# Site URL (use ngrok for local dev)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
